          rgba="0.752941176470588 0.752941176470588 0.752941176470588 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://joyrebot_gazebo_sim/meshes/pla_right.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="joint_right"
    type="prismatic">
    <origin
      xyz="-0.041939 7.3385E-05 0"
      rpy="-1.5708 -1.5708 0" />
    <parent
      link="gripper_end" />
    <child
      link="gripper_right" />
    <axis
      xyz="0 0 1" />
    <limit
      lower="0"
      upper="0.05"
      effort="500"
      velocity="10" />
    <dynamics damping="5.0" friction="0.5" />
  </joint>

  <!-- Gazebo Harmonic native position controllers. Commands are radians for
       joint1..joint6 and metres for the parallel gripper. -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher" />
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>joint1</joint_name><topic>/rebot/joint1/cmd_pos</topic><p_gain>18</p_gain><d_gain>2</d_gain><cmd_max>36</cmd_max><cmd_min>-36</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>joint2</joint_name><topic>/rebot/joint2/cmd_pos</topic><p_gain>35</p_gain><d_gain>3</d_gain><cmd_max>36</cmd_max><cmd_min>-36</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <!-- joint3 carries the complete wrist / gripper chain.  The MuJoCo
           gain (18) cannot lift it from the lower stop in Gazebo under
           gravity, so use a stiffer, better damped position loop while
           retaining the physical 36 N.m effort limit. -->
      <joint_name>joint3</joint_name><topic>/rebot/joint3/cmd_pos</topic><p_gain>100</p_gain><d_gain>6</d_gain><cmd_max>36</cmd_max><cmd_min>-36</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>joint4</joint_name><topic>/rebot/joint4/cmd_pos</topic><p_gain>45</p_gain><d_gain>4</d_gain><cmd_max>14</cmd_max><cmd_min>-14</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>joint5</joint_name><topic>/rebot/joint5/cmd_pos</topic><p_gain>12</p_gain><d_gain>2</d_gain><cmd_max>14</cmd_max><cmd_min>-14</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>joint6</joint_name><topic>/rebot/joint6/cmd_pos</topic><p_gain>50</p_gain><d_gain>2</d_gain><cmd_max>14</cmd_max><cmd_min>-14</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>joint_left</joint_name><topic>/rebot/gripper/cmd_pos</topic><p_gain>250</p_gain><d_gain>25</d_gain><cmd_max>500</cmd_max><cmd_min>-500</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>joint_right</joint_name><topic>/rebot/gripper/cmd_pos</topic><p_gain>250</p_gain><d_gain>25</d_gain><cmd_max>500</cmd_max><cmd_min>-500</cmd_min>
    </plugin>
  </gazebo>
</robot>
